    }

    /* ===== FORNITORI: tessere con bordo doppio ===== */
    .fornitori {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
        margin-top: 16px;
    }

    @media (min-width: 600px) { .fornitori { grid-template-columns: repeat(3, 1fr); } }
