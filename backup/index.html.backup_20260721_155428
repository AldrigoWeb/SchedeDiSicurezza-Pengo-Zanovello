        background: linear-gradient(175deg, var(--rosso-scuro) 0%, #430c0a 100%);
        color: var(--crema-carta);
        position: relative;
    }

    .azienda::before{
        content:"";
        position:absolute;
        left:0; right:0; top:8px;
        height:1px;
        background: rgba(232,197,131,0.45);
        margin: 0 20px;
    }

    .azienda::after{
        content:"";
        position:absolute;
        left:0; right:0; bottom:0;
        height:0;
        border-bottom: 5px double var(--oro);
        margin: 0 20px;
    }

    .eyebrow{
        font-family:'IBM Plex Mono', monospace;
        font-size: 11px;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--oro-chiaro);
