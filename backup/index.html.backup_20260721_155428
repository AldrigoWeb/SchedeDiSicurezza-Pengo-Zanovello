        font-family:'Inter',Arial,sans-serif;
        margin-bottom: 10px;
        border: 1.5px solid var(--oro);
        border-radius: 3px;
        background: var(--crema-carta);
        color: var(--inchiostro);
        transition: border-color .15s, box-shadow .15s;
    }

    #searchBox:focus{
