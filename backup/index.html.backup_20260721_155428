<script src="pdfList.js"></script>
<script>
function cleanPdfName(filename) {
    let name = filename.replace(".pdf", "");
    name = name.replace(/SDS|EU|FORMAT|ITALIAN/gi, "");
    name = name.replace(/[A-Z]{2,}-\d{2,}(-\d+)?/gi, "");
    name = name.replace(/\d{4,}/g, "");
    name = name.replace(/[_\-]+/g, " ");
    return name.trim();
}

const searchBox = document.getElementById("searchBox");
const results = document.getElementById("searchResults");

searchBox.addEventListener("input", function() {
    const query = this.value.toLowerCase();
    results.innerHTML = "";
    if (!query) return;

    const filtered = pdfList.filter(pdf =>
        cleanPdfName(pdf.split("/").pop()).toLowerCase().includes(query)
    );

    if (!filtered.length) {
        results.innerHTML = "<li>Nessun PDF trovato</li>";
        return;
    }

    filtered.forEach(pdf => {
        const fileName = pdf.split("/").pop();
        const displayName = cleanPdfName(fileName);
        const li = document.createElement("li");
        li.innerHTML = `<span class="rombo piccolo rosso"></span><a href="${pdf}" target="_blank">${displayName}</a>`;
        results.appendChild(li);
    });
});
</script>

