        width:8px; height:8px;
        background: var(--oro);
        transform: rotate(45deg);
        flex: 0 0 auto;
    }
    .rombo.piccolo{ width:5px; height:5px; }
    .rombo.rosso{ background: var(--rosso); }

    .divisore-rombi{
        display:flex;
        align-items:center;
        justify-content:center;
        gap:9px;
        margin: 0 0 4px;
    }
    .divisore-rombi::before,
    .divisore-rombi::after{
        content:"";
        height:1px;
        width:34px;
        background: var(--oro-chiaro);
        opacity:.55;
    }

    /* ===== TESTATA: blocco d'inchiostro rosso ===== */
    .azienda {
